{
  "name": "booksocial-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "BookSocial Studio — quality & release tooling (Prettier, ESLint) for server/ and web/.",
  "scripts": {
    "format": "prettier --write \"server/src/**/*.{ts,tsx}\" \"web/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"server/src/**/*.{ts,tsx}\" \"web/src/**/*.{ts,tsx}\"",
    "lint": "eslint \"server/src/**/*.{ts,tsx}\" \"web/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.18.2"
  }
}
